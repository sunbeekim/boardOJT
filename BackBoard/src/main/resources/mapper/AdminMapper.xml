<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.board.dao.AdminMapper">

    <!-- 게시글 삭제 (관리자) -->
    <delete id="deletePostByAdmin" parameterType="long">
        DELETE FROM posts
        WHERE id = #{postId}
    </delete>

    <!-- 댓글 삭제 (관리자) -->
    <delete id="deleteCommentByAdmin" parameterType="long">
        DELETE FROM comments
        WHERE id = #{commentId}
    </delete>

    <!-- 사용자 계정 삭제 (관리자) -->
    <delete id="deleteUserAccount" parameterType="long">
        DELETE FROM users
        WHERE id = #{userId}
    </delete>

    <!-- 잠금 계정 해제 (관리자) -->
    <update id="unlockUserAccount" parameterType="long">
        UPDATE users
        SET locked = false,
            login_fail_count = 0
        WHERE id = #{userId}
    </update>

</mapper>